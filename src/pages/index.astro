---
import Layout from "../layouts/Layout.astro";
import AboutCard from "../components/AboutCard.astro";
import ExperienceCard from "../components/ExperienceCard.astro";
import SkillsCard from "../components/SkillsCard.astro";
import CertsCoursesCard from "../components/CertsCoursesCard.astro";
import Footer from "../components/Footer.astro";
---

<Layout
  title="Duy Pham — Associate Product Manager"
  description="Duy Pham — Associate Product Manager with 5+ years building fintech platforms and AI systems across Southeast Asia. Previously a Software Engineer."
>
  <!-- About: full width -->
  <div class="md:col-span-2">
    <AboutCard />
  </div>

  <!-- Experience: full width -->
  <div class="md:col-span-2">
    <ExperienceCard />
  </div>

  <!-- Skills: left half -->
  <SkillsCard />

  <!-- Certs & Courses: right half -->
  <CertsCoursesCard />

  <!-- Footer: full width -->
  <div class="md:col-span-2">
    <Footer />
  </div>
</Layout>
