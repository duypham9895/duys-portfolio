---
/*
 * Two-state toggle: light ↔ dark.
 * On first visit (no stored choice) the inline script in Layout.astro picks
 * up OS preference. After the user clicks, the choice is persisted.
 */
---

<button
  id="theme-toggle"
  type="button"
  class="theme-toggle"
  aria-label="Switch theme"
  title="Switch theme"
>
  {/* Sun: visible in light mode (means: click to go dark) */}
  <svg class="icon icon-light" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="12" cy="12" r="4"></circle>
    <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"></path>
  </svg>
  {/* Moon: visible in dark mode (means: click to go light) */}
  <svg class="icon icon-dark" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
  </svg>
</button>

<style>
  .theme-toggle {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    border: 0.5px solid var(--border);
    background: transparent;
    color: var(--text);
    display: inline-grid;
    place-items: center;
    cursor: pointer;
    transition: background-color 150ms ease, border-color 150ms ease;
  }

  .theme-toggle:hover {
    background-color: var(--surface-hover);
    border-color: var(--muted);
  }

  .theme-toggle .icon {
    grid-area: 1 / 1;
    opacity: 0;
    pointer-events: none;
    transition: opacity 150ms ease;
  }

  :global(html[data-theme="light"]) .theme-toggle .icon-light,
  :global(html[data-theme="dark"]) .theme-toggle .icon-dark {
    opacity: 1;
  }
</style>

<script>
  type Theme = "light" | "dark";

  const button = document.getElementById("theme-toggle");
  if (button) {
    const labelFor = (theme: Theme): string =>
      `Switch to ${theme === "light" ? "dark" : "light"} mode`;

    const current = (): Theme =>
      document.documentElement.dataset.theme === "dark" ? "dark" : "light";

    const updateResumeLink = (theme: Theme): void => {
      const link = document.getElementById("resume-link");
      if (!link) return;
      const href = link.getAttribute(`data-resume-${theme}`);
      if (href) link.setAttribute("href", href);
    };

    const apply = (theme: Theme): void => {
      document.documentElement.dataset.theme = theme;
      button.setAttribute("aria-label", labelFor(theme));
      updateResumeLink(theme);
      try {
        localStorage.setItem("theme", theme);
      } catch {}
    };

    button.setAttribute("aria-label", labelFor(current()));

    button.addEventListener("click", () => {
      apply(current() === "light" ? "dark" : "light");
    });

    // If no manual choice yet, follow OS changes.
    const mq = window.matchMedia("(prefers-color-scheme: dark)");
    mq.addEventListener("change", (e) => {
      try {
        if (!localStorage.getItem("theme")) {
          const next: Theme = e.matches ? "dark" : "light";
          document.documentElement.dataset.theme = next;
          button.setAttribute("aria-label", labelFor(next));
          updateResumeLink(next);
        }
      } catch {}
    });
  }
</script>
