---
import { personal } from "../data/personal";
---

<footer class="fade-in text-center py-8 mt-4 border-t border-border">
  <p class="text-sm text-muted mb-3">
    Interested in working together?
  </p>
  <a
    href={`mailto:${personal.contact.email}`}
    class="text-accent hover:underline underline-offset-4 text-sm font-medium"
  >
    {personal.contact.email}
  </a>
  <p class="text-[11px] text-muted mt-6">
    Built with Astro &middot; {new Date().getFullYear()}
  </p>
</footer>
