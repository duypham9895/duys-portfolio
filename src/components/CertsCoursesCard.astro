---
import { certifications } from "../data/certifications";
---

<div class="card fade-in" id="certs">
  <h2 class="section-label">Certifications & Courses</h2>
  <div class="flex flex-col gap-2.5">
    {certifications.map((cert) => (
      <a
        href={cert.credentialUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="group flex items-center justify-between p-3.5 bg-bg border border-border rounded-xl hover:border-accent transition-colors"
      >
        <div>
          <h3 class="text-[13px] font-medium text-text">{cert.name}</h3>
          <p class="text-[11px] text-muted mt-1">
            {cert.organization} &middot; {cert.date}
          </p>
        </div>
        <svg class="w-4 h-4 text-muted group-hover:text-accent transition-colors flex-shrink-0 ml-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M7 17L17 7M17 7H7M17 7v10" />
        </svg>
      </a>
    ))}
  </div>
</div>
