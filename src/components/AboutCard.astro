---
import { personal } from "../data/personal";

function renderBoldedHtml(text: string): string {
  return text.replace(
    /\*\*([^*]+)\*\*/g,
    '<strong class="text-[#fafafa] font-medium">$1</strong>'
  );
}
---

<div class="card fade-in" id="about">
  <h2 class="section-label">About Me</h2>
  {
    personal.bio.map((paragraph) => (
      <p
        class="text-sm text-[#a1a1aa] leading-[1.85] mb-4 last:mb-0"
        set:html={renderBoldedHtml(paragraph)}
      />
    ))
  }
</div>
