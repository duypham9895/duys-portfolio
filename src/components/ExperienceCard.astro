---
import { experiences } from "../data/experiences";
---

<div class="card fade-in" id="experience">
  <h2 class="section-label">Experience</h2>
  <div class="relative pl-6">
    <!-- Timeline line -->
    <div class="absolute left-[5px] top-[10px] bottom-[10px] w-px bg-border"></div>

    {experiences.map((exp, i) => (
      <div class:list={["relative", { "mb-7": i < experiences.length - 1 }]}>
        <!-- Timeline dot — mustard, the categorical accent -->
        <div
          class="absolute -left-6 top-2 w-[11px] h-[11px] rounded-full"
          style="background: var(--accent-2); box-shadow: 0 0 0 3px var(--bg);"
        ></div>

        <div class="flex justify-between items-baseline flex-wrap gap-2">
          <h3 class="text-base font-semibold text-text">{exp.jobTitle}</h3>
          <span class="text-[11px] text-muted whitespace-nowrap">
            {exp.startDate} — {exp.endDate ?? "Present"}
          </span>
        </div>
        <a
          href={exp.companyUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="text-[13px] text-accent block mt-1 mb-2.5 hover:underline underline-offset-4"
        >
          {exp.companyName}
        </a>
        <ul class="text-[12.5px] text-muted pl-4 leading-[1.75] list-disc">
          {exp.description.map((item) => (
            <li class="mb-1">{item}</li>
          ))}
        </ul>
      </div>
    ))}
  </div>
</div>
