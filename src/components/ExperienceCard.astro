---
import { experiences } from "../data/experiences";
---

<div class="card fade-in" id="experience">
  <h2 class="section-label">Experience</h2>
  <div class="relative pl-6">
    <!-- Timeline line -->
    <div class="absolute left-[5px] top-[10px] bottom-[10px] w-px bg-gradient-to-b from-primary/30 to-primary/5"></div>

    {experiences.map((exp, i) => (
      <div class:list={["relative", { "mb-7": i < experiences.length - 1 }]}>
        <!-- Timeline dot -->
        <div class="absolute -left-6 top-2 w-[11px] h-[11px] rounded-full bg-primary border-[3px] border-[#0a0a0b] shadow-[0_0_0_2px_rgba(250,82,82,0.2)]"></div>

        <div class="flex justify-between items-baseline flex-wrap gap-2">
          <h3 class="text-base font-semibold">{exp.jobTitle}</h3>
          <span class="text-[11px] text-[#71717a] whitespace-nowrap">
            {exp.startDate} — {exp.endDate ?? "Present"}
          </span>
        </div>
        <a
          href={exp.companyUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="text-[13px] text-primary block mt-1 mb-2.5 hover:underline"
        >
          {exp.companyName}
        </a>
        <ul class="text-[12.5px] text-[#a1a1aa] pl-4 leading-[1.75] list-disc">
          {exp.description.map((item) => (
            <li class="mb-1">{item}</li>
          ))}
        </ul>
      </div>
    ))}
  </div>
</div>
