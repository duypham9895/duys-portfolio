---
import { Image } from "astro:assets";
import avatarImg from "../assets/avatar.jpg";
import { personal } from "../data/personal";
import { socialIcons } from "../data/icons";

const { fullName, title, contact, socials, resumeUrl } = personal;
---

<aside class="relative lg:sticky lg:top-6 h-fit max-w-[400px] mx-auto lg:max-w-none">
  <div class="bg-white/[0.025] border border-white/[0.06] rounded-3xl px-6 pt-9 pb-7 text-center relative overflow-hidden">
    <!-- Avatar glow -->
    <div class="absolute -top-10 left-1/2 -translate-x-1/2 w-[240px] h-[240px] bg-primary/[0.15] rounded-full blur-3xl pointer-events-none"></div>

    <!-- Avatar -->
    <div class="relative z-10 mx-auto mb-5 w-[180px] h-[180px] rounded-full p-[3px] bg-gradient-to-br from-primary to-primary-dark">
      <Image
        src={avatarImg}
        alt={fullName}
        width={360}
        height={360}
        format="webp"
        quality={85}
        class="rounded-full w-full h-full object-cover"
      />
    </div>

    <h1 class="text-[22px] font-bold relative z-10">{fullName}</h1>
    <p class="text-sm text-[#a1a1aa] mt-2 leading-relaxed relative z-10">
      {title}
    </p>

    <!-- Divider -->
    <div class="h-px bg-white/[0.06] my-5"></div>

    <!-- Contact info -->
    <div class="text-left space-y-3">
      {Object.entries(contact).map(([key, value]) => (
        <div class="border-b border-white/[0.06] pb-3 last:border-b-0 last:pb-0">
          <span class="text-[10px] text-[#71717a] uppercase tracking-wider block mb-1">{key}</span>
          <span class="text-[13px] text-[#a1a1aa] block break-all">{value}</span>
        </div>
      ))}
    </div>

    <!-- Social icons -->
    <div class="flex justify-center gap-2 mt-5">
      {socials.map((social) => (
        <a
          href={social.url}
          target="_blank"
          rel="noopener noreferrer"
          class="social-icon"
          aria-label={social.title}
          title={social.title}
          set:html={socialIcons[social.icon] || social.title.slice(0, 2)}
        />
      ))}
    </div>

    <!-- Resume button (hidden until PDF is ready) -->
    {resumeUrl && (
      <a
        href={resumeUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="block w-full border border-primary/40 text-primary py-3.5 rounded-[14px] text-[13px] font-semibold mt-5 hover:bg-primary/10 hover:border-primary/60 transition-all text-center"
      >
        View Resume
      </a>
    )}
  </div>
</aside>
