---
import { Image } from "astro:assets";
import avatarImg from "../assets/avatar.jpg";
import { personal } from "../data/personal";
import { socialIcons } from "../data/icons";
import ThemeToggle from "./ThemeToggle.astro";

const { fullName, title, contact, socials, resumeUrls } = personal;
const pathname = Astro.url.pathname;
const navLinks = [
  { href: "/", label: "Portfolio", active: pathname === "/" },
  { href: "/labs", label: "Labs", active: pathname.startsWith("/labs") },
];
---

<aside class="relative lg:sticky lg:top-6 h-fit">
  <div class="bg-surface border border-border rounded-xl px-6 pt-9 pb-7 text-center relative overflow-hidden">
    <!-- Theme toggle: top-right -->
    <div class="absolute top-4 right-4 z-20">
      <ThemeToggle />
    </div>

    <!-- Avatar -->
    <div class="relative z-10 mx-auto mb-5 w-[180px] h-[180px] rounded-full p-[3px]" style="background: var(--accent);">
      <Image
        src={avatarImg}
        alt={fullName}
        width={360}
        height={360}
        format="webp"
        quality={85}
        class="rounded-full w-full h-full object-cover"
      />
    </div>

    <h1 class="text-[22px] font-bold relative z-10 text-text">{fullName}</h1>
    <p class="text-sm text-muted mt-2 leading-relaxed relative z-10">
      {title}
    </p>

    <!-- Divider -->
    <div class="h-px bg-border my-5"></div>

    <nav class="grid grid-cols-2 gap-2 mb-5" aria-label="Site navigation">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={[
            "rounded-[12px] border px-3 py-2.5 text-[12px] font-semibold transition-colors",
            link.active
              ? "bg-accent text-bg border-accent"
              : "bg-surface-hover text-muted border-border hover:border-accent hover:text-accent",
          ]}
          aria-current={link.active ? "page" : undefined}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <!-- Contact info -->
    <div class="text-left space-y-3">
      {Object.entries(contact).map(([key, value]) => (
        <div class="border-b border-border pb-3 last:border-b-0 last:pb-0">
          <span class="text-[10px] text-muted uppercase tracking-wider block mb-1">{key}</span>
          <span class="text-[13px] text-text block break-all">{value}</span>
        </div>
      ))}
    </div>

    <!-- Social icons -->
    <div class="flex justify-center gap-2 mt-5">
      {socials.map((social) => (
        <a
          href={social.url}
          target="_blank"
          rel="noopener noreferrer"
          class="social-icon"
          aria-label={social.title}
          title={social.title}
          set:html={socialIcons[social.icon] || social.title.slice(0, 2)}
        />
      ))}
    </div>

    <!-- Resume button — href swapped to match active theme by ThemeToggle/FOUC script -->
    <a
      id="resume-link"
      href={resumeUrls.light}
      data-resume-light={resumeUrls.light}
      data-resume-dark={resumeUrls.dark}
      target="_blank"
      rel="noopener noreferrer"
      class="block w-full bg-accent text-bg py-3.5 rounded-[14px] text-[13px] font-semibold mt-5 hover:bg-accent-hover transition-colors text-center"
    >
      View Resume
    </a>
  </div>
</aside>
